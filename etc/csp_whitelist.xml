<?xml version="1.0"?>
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
    <policies>
        <policy id="script-src">
            <values>
                <value id="payhub" type="host">app.payhub.ly</value>
                <value id="payhub-demo" type="host">demo.payhub.ly</value>
                <value id="moamalat" type="host">tnpg.moamalat.net</value>
            </values>
        </policy>
        <policy id="frame-src">
            <values>
                <value id="payhub" type="host">app.payhub.ly</value>
                <value id="moamalat" type="host">tnpg.moamalat.net</value>
            </values>
        </policy>
        <policy id="connect-src">
            <values>
                <value id="payhub" type="host">app.payhub.ly</value>
                <value id="qrserver" type="host">api.qrserver.com</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>
